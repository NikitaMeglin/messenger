# База данных PostgreSQL
DATABASE_URL=postgresql://messenger:secret123@postgres:5432/messenger

# Redis для WebSocket Pub/Sub
REDIS_URL=redis://redis:6379

# Секретный ключ для JWT (в проде замените на сложный)
SECRET_KEY=your-super-secret-key-change-this-in-production-123456

# Режим разработки
DEBUG=True